# Bundler manifest for the GitHub Pages docs.
#
# `actions/setup-ruby` will install these via Bundler before running
# `jekyll build` in the Pages workflow. We pin to compatible release
# bands so a fresh CI run isn't surprised by a major theme bump.

source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "just-the-docs", "~> 0.10"

group :jekyll_plugins do
  gem "jekyll-remote-theme", "~> 0.4"
  gem "jekyll-seo-tag",      "~> 2.8"
  gem "jekyll-sitemap",      "~> 1.4"
  gem "jekyll-feed",         "~> 0.17"
end

# Required on Windows / JRuby for proper file watching support.
gem "wdm", "~> 0.1.1", platforms: [:mingw, :x64_mingw, :mswin]
gem "tzinfo-data",     platforms: [:mingw, :x64_mingw, :mswin, :jruby]
